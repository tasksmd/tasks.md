{
  "name": "tasks-mcp",
  "version": "0.1.0",
  "description": "MCP server for reading and writing TASKS.md files",
  "type": "module",
  "bin": {
    "tasks-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "tasks",
    "ai-agents",
    "task-queue",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tasksmd/tasks.md",
    "directory": "mcp"
  },
  "homepage": "https://tasks.md",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
