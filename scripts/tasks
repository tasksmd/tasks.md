#!/bin/bash
# tasks — unified CLI for TASKS.md task queue management.
#
# Usage: tasks <command> [options]
#
# Commands:
#   init [--install]          Initialize a task queue in the current repo
#   install [--all] [--hooks] Install /next-task for detected agents
#   lint [--fix] <files...>   Validate TASKS.md files
#   pick [--tags TAGS]        Pick the best task to work on next
#   sync-issues [options]     Sync GitHub Issues into TASKS.md
#   stats                     Show task completion throughput from git history
#   diff [REF]                Show queue changes since last commit (or REF)
#   generate-commands         Regenerate agent command files from canonical source
#   help                      Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

show_help() {
  cat << 'EOF'
tasks — unified CLI for TASKS.md task queue management

Usage: tasks <command> [options]

Commands:
  init [--install]          Initialize a task queue in the current repo
  install [--all] [--hooks] Install /next-task for detected agents
  lint [--fix] <files...>   Validate TASKS.md files against the spec
  pick [--tags TAGS]        Pick the best task to work on next (requires tasks-mcp)
  sync-issues [options]     Sync GitHub Issues into TASKS.md
  stats                     Show task completion throughput from git history
  diff [REF]                Show queue changes since last commit (or REF)
  generate-commands         Regenerate agent command files from canonical source
  help                      Show this help

Examples:
  tasks init                Create TASKS.md + AGENTS.md section
  tasks lint TASKS.md       Validate a file
  tasks lint --fix .        Fix issues in all .md files in current dir
  tasks install --all       Install /next-task for all agents
  tasks stats               Show completion history
EOF
}

case "${1:-help}" in
  init)
    shift
    exec bash "$SCRIPT_DIR/init.sh" "${PWD}" "$@"
    ;;

  install)
    shift
    exec bash "$SCRIPT_DIR/install.sh" "${PWD}" "$@"
    ;;

  lint)
    shift
    exec node "$REPO_DIR/lint/index.js" "$@"
    ;;

  pick)
    shift
    # Use tasks-mcp pick_task via node if available
    if [ -f "$REPO_DIR/mcp/dist/index.js" ]; then
      tags_arg=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --tags) tags_arg="$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      node -e "
        import { loadAllTasks } from '$REPO_DIR/mcp/dist/parser.js';
        import { pickTask } from '$REPO_DIR/mcp/dist/tools.js';
        const files = await loadAllTasks(process.cwd());
        const tags = '${tags_arg}'.split(',').filter(Boolean);
        const result = pickTask(files, { tags: tags.length ? tags : undefined });
        console.log(result.text);
      "
    else
      echo "Error: tasks-mcp not built. Run: cd mcp && npm run build" >&2
      exit 1
    fi
    ;;

  sync-issues)
    shift
    exec bash "$SCRIPT_DIR/sync-issues.sh" "$@"
    ;;

  stats)
    shift
    git_root=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")

    # Discover all TASKS.md files
    task_files=()
    while IFS= read -r f; do
      task_files+=("$f")
    done < <(fd -t f "^TASKS\\.md$" "$git_root" --no-ignore-vcs 2>/dev/null)

    if [ ${#task_files[@]} -eq 0 ]; then
      echo "No TASKS.md files found" >&2
      exit 1
    fi

    # Concatenate all task files for parsing
    all_content=$(cat "${task_files[@]}")

    # ── Queue Overview ──
    echo "📋 Queue Overview"
    echo ""

    # Count tasks by priority
    current_priority=""
    p0=0; p1=0; p2=0; p3=0; total=0
    blocked=0; claimed=0

    while IFS= read -r line; do
      case "$line" in
        "## P0"*) current_priority="P0" ;;
        "## P1"*) current_priority="P1" ;;
        "## P2"*) current_priority="P2" ;;
        "## P3"*) current_priority="P3" ;;
        "## "*|"# "*) current_priority="" ;;
        "- [ ] "*)
          total=$((total + 1))
          case "$current_priority" in
            P0) p0=$((p0 + 1)) ;; P1) p1=$((p1 + 1)) ;;
            P2) p2=$((p2 + 1)) ;; P3) p3=$((p3 + 1)) ;;
          esac
          # Check if claimed (has @agent tag)
          if echo "$line" | grep -qE '\(@[^)]+\)'; then
            claimed=$((claimed + 1))
          fi
          ;;
        *"**Blocked by**"*)
          blocked=$((blocked + 1))
          ;;
      esac
    done <<< "$all_content"

    # Display priority breakdown
    printf "  %-4s %-4s %-4s %-4s  Total\n" "P0" "P1" "P2" "P3"
    printf "  %-4s %-4s %-4s %-4s  %s\n" "$p0" "$p1" "$p2" "$p3" "$total"
    echo ""
    echo "  Blocked: $blocked"
    echo "  Claimed: $claimed"
    echo "  Available: $((total - blocked - claimed))"

    # Oldest task — find the earliest commit that added the first task line still present
    echo ""
    oldest_age=""
    for task_file in "${task_files[@]}"; do
      first_task=$(grep -m1 '^- \[ \]' "$task_file" 2>/dev/null || true)
      [ -z "$first_task" ] && continue
      # Find when this line was added (git log -S)
      added_date=$(git -C "$git_root" log --all --diff-filter=A --format='%ai' -1 -- "$task_file" 2>/dev/null || true)
      if [ -n "$added_date" ]; then
        days_ago=$(( ( $(date +%s) - $(date -jf '%Y-%m-%d %H:%M:%S %z' "$added_date" +%s 2>/dev/null || date -d "$added_date" +%s 2>/dev/null || echo 0) ) / 86400 ))
        if [ -z "$oldest_age" ] || [ "$days_ago" -gt "$oldest_age" ]; then
          oldest_age="$days_ago"
        fi
      fi
    done
    if [ -n "$oldest_age" ] && [ "$oldest_age" -gt 0 ]; then
      echo "  Oldest file: ${oldest_age}d ago"
    fi

    # Files summary
    echo "  Files: ${#task_files[@]}"

    # ── Throughput ──
    echo ""
    echo "📊 Throughput"
    echo ""

    # Count completed tasks from git diffs (removed "- [ ]" lines)
    total_completed=$(git -C "$git_root" log --all -p -- "*/TASKS.md" "TASKS.md" 2>/dev/null \
      | grep -c '^-- \[ \]' || true)
    week_completed=$(git -C "$git_root" log --all --since="1 week ago" -p -- "*/TASKS.md" "TASKS.md" 2>/dev/null \
      | grep -c '^-- \[ \]' || true)
    month_completed=$(git -C "$git_root" log --all --since="1 month ago" -p -- "*/TASKS.md" "TASKS.md" 2>/dev/null \
      | grep -c '^-- \[ \]' || true)

    echo "  Completed (all time):  $total_completed"
    echo "  Completed (this month): $month_completed"
    echo "  Completed (this week):  $week_completed"

    # Top agents
    agents=$(git -C "$git_root" log --all -p -- "*/TASKS.md" "TASKS.md" 2>/dev/null \
      | grep '^-- \[ \].*(@' \
      | grep -oE '\(@[^)]+\)' \
      | sort | uniq -c | sort -rn | head -5 || true)

    if [ -n "$agents" ]; then
      echo ""
      echo "  Top agents:"
      echo "$agents" | while read -r count agent; do
        echo "    $agent: $count task(s)"
      done
    fi
    ;;

  diff)
    shift
    ref="${1:-HEAD}"
    git_root=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")

    # Get diff for all TASKS.md files
    diff_output=$(git -C "$git_root" diff "$ref" -- "*/TASKS.md" "TASKS.md" 2>/dev/null || true)

    if [ -z "$diff_output" ]; then
      echo "No TASKS.md changes since $ref"
      exit 0
    fi

    # Extract added tasks (lines starting with +- [ ])
    added=$(echo "$diff_output" | grep '^+- \[ \]' | sed 's/^+//' || true)
    # Extract removed tasks (lines starting with -- [ ])
    removed=$(echo "$diff_output" | grep '^-- \[ \]' | sed 's/^-//' || true)
    # Extract newly claimed tasks (added lines with @agent tag)
    claimed=$(echo "$diff_output" | grep '^+- \[ \].*(@' | sed 's/^+//' || true)

    added_count=$(echo "$added" | grep -c '^\- \[ \]' || true)
    removed_count=$(echo "$removed" | grep -c '^\- \[ \]' || true)
    claimed_count=$(echo "$claimed" | grep -c '^\- \[ \]' || true)

    echo "📋 Queue Changes (since $ref)"
    echo ""

    if [ "$removed_count" -gt 0 ]; then
      echo "  ✅ Removed ($removed_count):"
      echo "$removed" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        # Strip "- [ ] " prefix for cleaner display
        task="${line#- \[ \] }"
        echo "    $task"
      done
      echo ""
    fi

    if [ "$added_count" -gt 0 ]; then
      echo "  ➕ Added ($added_count):"
      echo "$added" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        task="${line#- \[ \] }"
        echo "    $task"
      done
      echo ""
    fi

    if [ "$claimed_count" -gt 0 ]; then
      echo "  🔒 Claimed ($claimed_count):"
      echo "$claimed" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        task="${line#- \[ \] }"
        echo "    $task"
      done
      echo ""
    fi

    echo "  Summary: +$added_count added, -$removed_count removed, $claimed_count claimed"
    ;;

  generate-commands)
    shift
    exec bash "$SCRIPT_DIR/generate-commands.sh" "$@"
    ;;

  help|--help|-h)
    show_help
    ;;

  *)
    echo "Unknown command: $1" >&2
    echo "" >&2
    echo "Run 'tasks help' for usage." >&2
    exit 1
    ;;
esac
